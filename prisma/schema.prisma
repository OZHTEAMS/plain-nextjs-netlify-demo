generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  category  String   // Ej: "Economía", "Inversión", "Noticias"
  slug      String   @unique
  published Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SuccessStory {
  id           String   @id @default(cuid())
  nombre       String
  bio          String   @db.Text
  categoria    String
  linkedin_url String?
  image_url    String?
  createdAt    DateTime @default(now())
}
